# ─── Server ───────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (SQL Server) ────────────────────
# Format: sqlserver://HOST:PORT;database=DB_NAME;user=USER;password=PASS;encrypt=true;trustServerCertificate=true
DATABASE_URL="sqlserver:LAPTOP-8EPKMA78//localhost:1433;database=LuxStayDB;user=sa;password=YourPassword123!;encrypt=true;trustServerCertificate=true"

# ─── JWT ──────────────────────────────────────
JWT_SECRET=luxstay_super_secret_key_change_in_prod
JWT_EXPIRES_IN=7d

# ─── Email (Nodemailer) ───────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="LuxStay Hotel <no-reply@luxstay.vn>"

# ─── MoMo Payment ─────────────────────────────
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=luxstay://payment/result
MOMO_NOTIFY_URL=https://your-server.com/api/payments/momo/callback

# ─── App URLs ─────────────────────────────────
FRONTEND_URL=http://localhost:8081
API_BASE_URL=http://localhost:3000
